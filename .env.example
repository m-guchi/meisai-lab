# アプリ実行時に参照する環境変数（値は空。ローカルは .env.local.example を参照）
DATABASE_URL=
AUTH_URL=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ログイン通知（任意。未設定なら通知しない）
SIGNALY_LOGIN_WEBHOOK_URL=

# デプロイ時のみ使用（DATABASE_URL の組み立て元。scripts/construct-database-url.sh）
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=

# CI/デプロイ通知
SIGNALY_WEBHOOK_URL=
