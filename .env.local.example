# cp .env.local.example .env.local
#
# ローカル開発用。1Password は不要（本番は .github/deploy.env.tpl 経由で1Passwordから注入）。
# Google OAuth は開発用と本番用でGoogle Cloudのプロジェクト/クライアントを分けること。
#   開発用クライアントの承認済みリダイレクトURI: http://localhost:3000/api/auth/callback/google

DATABASE_URL=mysql://meisai_lab:devpassword@127.0.0.1:3306/app_meisai_lab_dev

AUTH_URL=http://localhost:3000
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
